{
  "version": "1.0",
  "include": ["src/**/*.ts"],
  "exclude": ["**/node_modules/**", "**/dist/**"],

  "passes": {
    "naming-convention": false,
    "unbounded-collection": false,
    "redundant-loop-computation": false,
    "dependency-fan-out": { "threshold": 35 }
  },

  "suppressions": [
    {
      "pass": "unhandled-exception",
      "file": "src/cli.ts",
      "reason": "CLI throws for invalid arguments/config - standard CLI pattern"
    },
    {
      "pass": "missing-stream",
      "file": "src/cli.ts",
      "reason": "Analyzer requires complete file content as string - streaming not applicable"
    },
    {
      "pass": "infinite-loop",
      "file": "src/formatters.ts",
      "reason": "for...of loop terminates when taintPaths iterator exhausted - pass doesn't recognize implicit termination"
    }
  ],

  "severity": "low",
  "categories": ["security", "reliability", "performance", "maintainability", "architecture"]
}
